{
  "name": "dls-design-tokens",
  "version": "1.0.0",
  "description": "DLS Design System — Design Tokens",
  "scripts": {
    "start": "node scripts/generate-changelog.mjs --write && node server.js",
    "changelog": "node scripts/generate-changelog.mjs --write",
    "sync-components": "node scripts/sync-components.mjs --check",
    "figma:audit": "node scripts/figma-sync-audit.mjs",
    "storybook": "cd apps/storybook && npm run storybook",
    "storybook:typecheck": "cd apps/storybook && npx tsc -b",
    "tokens:lint": "node .claude/hooks/lint-tokens.mjs --all"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "agentation": "^2.2.1",
    "playwright": "^1.58.2"
  }
}
