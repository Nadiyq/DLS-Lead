{
  "name": "Button",
  "kebabName": "button",
  "category": "action",
  "description": "Native button action control for CTAs, row actions, toolbar actions, modal actions, and compact inline actions, with filled as the primary action treatment, outline as the secondary action treatment, soft as a tonal supporting treatment, dotted as a dashed optional-action treatment, ghost as a borderless tertiary treatment, and link as an inline text-style action treatment.",
  "variants": [
    "filled",
    "outline",
    "soft",
    "dotted",
    "ghost",
    "link"
  ],
  "intents": [
    "neutral",
    "primary",
    "info",
    "success",
    "warning",
    "danger"
  ],
  "sizes": [
    "m",
    "s"
  ],
  "props": [
    {
      "name": "variant",
      "type": "ButtonVariant",
      "required": false,
      "default": "filled",
      "enum": [
        "filled",
        "outline",
        "soft",
        "dotted",
        "ghost",
        "link"
      ],
      "description": "Visual treatment for the action."
    },
    {
      "name": "intent",
      "type": "ButtonIntent",
      "required": false,
      "default": "neutral",
      "enum": [
        "neutral",
        "primary",
        "info",
        "success",
        "warning",
        "danger"
      ],
      "description": "Semantic intent that controls color tokens."
    },
    {
      "name": "size",
      "type": "ButtonSize",
      "required": false,
      "default": "m",
      "enum": [
        "m",
        "s"
      ],
      "description": "Button height, typography, padding, and icon slot size."
    },
    {
      "name": "icon",
      "type": "React.ReactNode",
      "required": false,
      "description": "Optional leading icon. Use lucide-react icons."
    },
    {
      "name": "iconEnd",
      "type": "React.ReactNode",
      "required": false,
      "description": "Optional trailing icon. Use lucide-react icons."
    },
    {
      "name": "iconOnly",
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Hide visible label content and render a square icon button. Requires an accessible name."
    },
    {
      "name": "children",
      "type": "React.ReactNode",
      "required": false,
      "description": "Visible button label unless iconOnly is true."
    },
    {
      "name": "disabled",
      "type": "boolean",
      "required": false,
      "description": "Disable native button interaction and apply disabled tokens."
    },
    {
      "name": "className",
      "type": "string",
      "required": false,
      "description": "Additional class name for the root button."
    }
  ],
