{
  "name": "dls-design-tokens",
  "version": "1.0.0",
  "description": "DLS-Lead design tokens for products, design tools, and AI coding agents",
  "main": "./tokens/tokens.json",
  "style": "./tokens/tokens.css",
  "sass": "./tokens/tokens.scss",
  "exports": {
    ".": "./tokens/tokens.json",
    "./tokens.json": "./tokens/tokens.json",
    "./tokens.css": "./tokens/tokens.css",
    "./tokens.scss": "./tokens/tokens.scss",
    "./tokens.ts": "./tokens/tokens.ts",
    "./ai": "./docs/ai-agent-token-consumption.md",
    "./specs/*": "./specs/*",
    "./prompts/*": "./prompts/*",
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "docs/ai-agent-token-consumption.md",
    "tokens/tokens.json",
    "tokens/tokens.css",
    "tokens/tokens.scss",
    "tokens/tokens.ts",
    "specs/**/*.md",
    "prompts/**/*.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nadiyq/DLS-Lead.git"
  },
  "bugs": {
    "url": "https://github.com/Nadiyq/DLS-Lead/issues"
  },
  "homepage": "https://github.com/Nadiyq/DLS-Lead#readme",
  "keywords": [
    "design-tokens",
    "dtcg",
    "dls-lead",
    "css-custom-properties",
    "figma",
    "storybook",
    "ai-agents",
    "llm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node scripts/generate-changelog.mjs --write && node server.js",
    "changelog": "node scripts/generate-changelog.mjs --write",
    "sync-components": "node scripts/sync-components.mjs --check",
    "figma:audit": "node scripts/figma-sync-audit.mjs",
    "storybook": "cd apps/storybook && npm run storybook",
    "storybook:typecheck": "cd apps/storybook && npx tsc -b",
    "tokens:lint": "node .claude/hooks/lint-tokens.mjs --all"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "agentation": "^2.2.1",
    "playwright": "^1.58.2"
  }
}
